  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 43523039232
    m_Localized: "\u041D\u0430\u0447\u0430\u0442\u044C \u0438\u0433\u0440\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 43564982272
    m_Localized: "\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 43564982273
    m_Localized: "\u0412\u044B\u0445\u043E\u0434"
    m_Metadata:
      m_Items: []
  - m_Id: 43564982274
    m_Localized: "\u0413\u0440\u043E\u043C\u043A\u043E\u0441\u0442\u044C \u0437\u0432\u0443\u043A\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 43569176576
    m_Localized: "\u0413\u0440\u043E\u043C\u043A\u043E\u0441\u0442\u044C \u043C\u0443\u0437\u044B\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 43569176577
    m_Localized: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 43569176578
    m_Localized: "\u0434\u043B\u044F \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 43569176579
    m_Localized: "\u0417\u0430\u0436\u043C\u0438\u0442\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 43569176580
    m_Localized: "\u0447\u0442\u043E\u0431\u044B \u043E\u0442\u0432\u0435\u0442\u0438\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 43569176581
    m_Localized: "\u0414\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 43569176582
    m_Localized: "\u041D\u0435\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 43569176584
    m_Localized: "\u0414\u0435\u043D\u044C \u0434\u043E\u0431\u0440\u044B\u0439 \u0445\u0443\u0435\u0431\u0440\u044B\u0439,
      \u0442\u043E\u0432\u0430\u0440\u0438\u0449 \u0441\u0435\u0440\u0436\u0430\u043D\u0442.
      \u041C\u0435\u043D\u044F \u0437\u043E\u0432\u0443\u0442 \u042D\u0434\u0432\u0430\u0440\u0434
      \u0414\u043E\u0443\u044D\u043B, \u044F \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0441\u0442.
      \u0422\u044B \u2013 \u043C\u043E\u0439 \u043D\u0430\u0432\u043E\u0434\u0447\u0438\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 43569176585
    m_Localized: "\u0421\u0435\u0439\u0447\u0430\u0441 \u0432\u043E\u0439\u0441\u043A\u0430
      \u0418\u043C\u043F\u0435\u0440\u0438\u0438 \u043F\u0440\u043E\u0432\u043E\u0434\u044F\u0442
      \u044D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u044E \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0438\u0445.
      \u041D\u0430\u0448 \u0434\u043E\u043B\u0433 \u2013 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0442\u044C
      \u0438\u043C \u043F\u0440\u0438\u043A\u0440\u044B\u0442\u0438\u0435. "
    m_Metadata:
      m_Items: []
  - m_Id: 43569176586
    m_Localized: "\u0414\u043B\u044F \u043D\u0430\u0447\u0430\u043B\u0430 \u0432\u043A\u043B\u044E\u0447\u0438
      \u043A\u0430\u0440\u0442\u0443 \u043D\u0430 \u0441\u0442\u043E\u043B\u0435.
      \u0422\u0430\u043C \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u0442\u044C
      \u0440\u0443\u0431\u0438\u043B\u044C\u043D\u0438\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 43569176587
    m_Localized: "\u0412\u043A\u043B\u044E\u0447\u0438\u043B? \u041C\u043E\u043B\u043E\u0434\u0435\u0446. "
    m_Metadata:
      m_Items: []
  - m_Id: 43569176588
    m_Localized: "\u041D\u0430\u0432\u043E\u0434\u0447\u0438\u043A, \u0442\u044B
      \u043E\u0431\u044F\u0437\u0430\u043D \u043F\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u0442\u044C
      \u043C\u043D\u0435 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B
      \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0430. \u041E\u043D
      \u043E\u0442\u043C\u0435\u0447\u0435\u043D \u043D\u0430 \u043A\u0430\u0440\u0442\u0435
      \u043A\u0440\u0430\u0441\u043D\u044B\u043C\u0438 \u0442\u043E\u0447\u043A\u0430\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 43569176589
    m_Localized: "\u0423\u0432\u0438\u0434\u0438\u0448\u044C \u0442\u0430\u043A\u0443\u044E
      \u2013 \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u0442\u0435\u043B\u0435\u0433\u0440\u0430\u0444\u0438\u0440\u0443\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 43569176590
    m_Localized: "\u0418 \u0434\u0430\u0436\u0435 \u043D\u0435 \u0434\u0443\u043C\u0430\u0439
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0434\u043B\u044F
      \u044D\u0442\u043E\u0433\u043E \u0442\u0435\u043B\u0435\u0444\u043E\u043D.
      \u041A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u043E\u043F\u0430\u0441\u0430\u0435\u0442\u0441\u044F
      \u043F\u0440\u043E\u0441\u043B\u0443\u0448\u0435\u043A. \u0422\u043E\u043B\u044C\u043A\u043E
      \u0442\u0435\u043B\u0435\u0433\u0440\u0430\u0444!"
    m_Metadata:
      m_Items: []
  - m_Id: 43569176591
    m_Localized: "\u0415\u0441\u043B\u0438 \u0443\u0441\u043B\u044B\u0448\u0438\u0448\u044C
      \u0441\u0438\u0440\u0435\u043D\u0443, \u0437\u043D\u0430\u0447\u0438\u0442,
      \u0432\u0440\u0430\u0433 \u043D\u0430\u043F\u0430\u0434\u0430\u0435\u0442.
      \u0421\u0432\u044F\u0437\u044C \u0432\u044B\u0440\u0443\u0431\u0430\u044E\u0442
      \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E, \u043D\u0430 \u043D\u0435\u0451
      \u043C\u043E\u0436\u0435\u0448\u044C \u043D\u0435 \u043F\u043E\u043B\u0430\u0433\u0430\u0442\u044C\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370880
    m_Localized: "\u0422\u0435\u0431\u0435 \u043F\u043E\u0432\u0435\u0437\u043B\u043E:
      \u043D\u0430 \u043F\u043E\u043B\u0435 \u0431\u043E\u044F \u043D\u0435\u0434\u043E\u0431\u0438\u0442\u044B\u0439
      \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A. \u041E\u043D \u0445\u043E\u0442\u044C
      \u0438 \u0436\u0438\u0432, \u043D\u043E \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
      \u043D\u0435 \u043C\u043E\u0436\u0435\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370881
    m_Localized: "\u0425\u043E\u0442\u044C \u043F\u043E\u0439\u043C\u0451\u0448\u044C,
      \u0447\u0442\u043E \u0434\u0430 \u043A\u0430\u043A, \u043F\u043E\u043A\u0430
      \u0433\u0430\u0440\u044C\u044E \u043D\u0435 \u0437\u0430\u043F\u0430\u0445\u043B\u043E. "
    m_Metadata:
      m_Items: []
  - m_Id: 43573370882
    m_Localized: "\u041F\u043E\u0432\u0442\u043E\u0440\u044E: \u0443\u0432\u0438\u0434\u0438\u0448\u044C
      \u0442\u043E\u0447\u043A\u0443 \u2013 \u043D\u0435 \u0436\u0434\u0438 \u0438
      \u0441\u0440\u0430\u0437\u0443 \u0436\u0435 \u0448\u043B\u0438 \u0435\u0451
      \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B \u043C\u043D\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370883
    m_Localized: "\u0412\u043E\u0442 \u0432\u0435\u0434\u044C. \u041F\u044F\u0442\u044C
      \u043B\u0435\u0442 \u043C\u044B \u043F\u043E\u0442\u0440\u0430\u0442\u0438\u043B\u0438,
      \u0447\u0442\u043E\u0431\u044B \u044D\u0442\u0430 \u0437\u0435\u043C\u043B\u044F
      \u0441\u0442\u0430\u043B\u0430 \u043D\u0430\u0448\u0435\u0439. "
    m_Metadata:
      m_Items: []
  - m_Id: 43573370884
    m_Localized: "\u0410 \u0432\u0440\u0430\u0433 \u0441\u043C\u0435\u0442\u0430\u0435\u0442
      \u0432\u0441\u0435 \u0443\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F
      \u0437\u0430 \u0441\u0447\u0438\u0442\u0430\u043D\u043D\u044B\u0435 \u0447\u0430\u0441\u044B\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370885
    m_Localized: "\u0425\u0432\u0430\u0442\u0438\u0442 \u0431\u043E\u043B\u0442\u043E\u0432\u043D\u0438.
      \u0411\u0443\u0434\u044C \u0433\u043E\u0442\u043E\u0432 \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C
      \u043C\u043D\u0435 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370886
    m_Localized: "\u041C\u043E\u043B\u043E\u0434\u0435\u0446, \u0441\u0435\u0440\u0436\u0430\u043D\u0442!
      \u0412\u0438\u0434\u0438\u0448\u044C, \u043D\u0435 \u0442\u0430\u043A \u0443\u0436
      \u0438 \u0441\u043B\u043E\u0436\u043D\u043E. \u0414\u0430 \u0438 \u044F \u043D\u0435
      \u043F\u0430\u043B\u044C\u0446\u0435\u043C \u0434\u0435\u043B\u0430\u043D\u043D\u044B\u0439,
      \u0441\u043E \u043C\u043D\u043E\u0439 \u043D\u0435 \u043F\u0440\u043E\u043F\u0430\u0434\u0451\u0448\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370887
    m_Localized: "\u0412\u043E\u0442 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
      \u043C\u043E\u043B\u043E\u0434\u0451\u0436\u044C \u0432\u043E\u043E\u0431\u0449\u0435
      \u0432 \u043A\u0443\u0440\u0441\u0435 \u043F\u0440\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u0435
      \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043D\u0438\u044F \u0418\u043C\u043F\u0435\u0440\u0438\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370888
    m_Localized: "\u0427\u0442\u043E \u0441\u0435\u0439\u0447\u0430\u0441 \u043F\u0440\u043E
      \u043D\u0430\u0441 \u0432 \u0448\u043A\u043E\u043B\u0435 \u0433\u043E\u0432\u043E\u0440\u044F\u0442?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370889
    m_Localized: "\u0421\u043E\u0432\u0441\u0435\u043C \u043D\u0435\u043C\u043D\u043E\u0433\u043E:
      \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u0430\u0442\u044B \u0434\u0430
      \u0438\u0442\u043E\u0433\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370890
    m_Localized: "\u0421\u0435\u0440\u044C\u0451\u0437\u043D\u043E? \u0412\u043E\u0441\u043F\u0438\u0442\u044B\u0432\u0430\u044E\u0442
      \u043F\u0440\u043E\u043F\u0430\u0449\u0435\u0435 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0435.
      \u041C\u044B, \u043C\u0435\u0436\u0434\u0443 \u043F\u0440\u043E\u0447\u0438\u043C,
      \u043F\u0440\u043E\u0448\u043B\u0438 \u0447\u0435\u0440\u0435\u0437 \u0430\u0434
      \u0440\u0430\u0434\u0438 \u0431\u043B\u0430\u0433\u0430 \u0418\u043C\u043F\u0435\u0440\u0438\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370891
    m_Localized: "\u041A\u0430\u0436\u0434\u044B\u0439 \u0433\u043E\u0434 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
      \u0443\u0440\u043E\u043A. \u0415\u0449\u0451 \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u043A
      \u043C\u043E\u0439 \u0431\u0435\u0437 \u0443\u043C\u0430 \u043E\u0442 \u044D\u0442\u043E\u0433\u043E
      \u0432\u0440\u0435\u043C\u0435\u043D\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370892
    m_Localized: "\u0420\u0430\u0434 \u0441\u043B\u044B\u0448\u0430\u0442\u044C.
      \u0425\u043E\u0440\u043E\u0448\u043E, \u0447\u0442\u043E \u0441\u0442\u0440\u0430\u043D\u0430
      \u043F\u043E\u043C\u043D\u0438\u0442 \u043D\u0430\u0448 \u043F\u043E\u0434\u0432\u0438\u0433."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370893
    m_Localized: "\u0411\u043E\u0438 \u0448\u043B\u0438 \u043D\u0430 \u044D\u0442\u043E\u043C
      \u0441\u0430\u043C\u043E\u043C \u043C\u0435\u0441\u0442\u0435. \u0414\u043E\u043B\u0433\u043E
      \u043E\u043D\u043E \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u043B\u043E
      \u043D\u0430\u043C. \u0418\u043C\u043F\u0435\u0440\u0438\u044F \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
      \u0441\u0438\u043B\u044C\u043D\u0435\u0435 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
      \u0442\u0430\u043A\u0438\u043C, \u043A\u0430\u043A \u043C\u044B \u0441 \u0442\u043E\u0431\u043E\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370894
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370895
    m_Localized: "\u0423 \u0442\u0435\u0431\u044F \u0442\u043E\u0436\u0435 \u0432\u0438\u0441\u044F\u0442
      \u044D\u0442\u0438 \u043F\u043B\u0430\u043A\u0430\u0442\u044B? \u041A\u0430\u043A
      \u0434\u0443\u043C\u0430\u0435\u0448\u044C, \u0447\u0442\u043E \u0437\u0430
      \u043C\u043E\u043D\u0441\u0442\u0440\u044B \u043D\u0430 \u043D\u0438\u0445
      \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u044B?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370896
    m_Localized: "\u041F\u043E\u043D\u044F\u0442\u0438\u044F \u043D\u0435 \u0438\u043C\u0435\u044E"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370897
    m_Localized: "\u041C\u044B! \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0448\u044C
      \u0441\u0435\u0431\u0435! \u041D\u0443 \u0438 \u0440\u043E\u0436\u0438, \u043A\u043E\u043D\u0435\u0447\u043D\u043E!
      \u042F \u043F\u0443\u0441\u0442\u044C \u0438 \u043D\u0435 \u043F\u0435\u0440\u0432\u044B\u0439
      \u043A\u0440\u0430\u0441\u0430\u0432\u0435\u0446, \u043D\u043E \u0442\u0443\u0442
      \u0443\u0436 \u0441\u043E\u0432\u0441\u0435\u043C \u0443\u0440\u043E\u0434\u0430
      \u043B\u0435\u043F\u044F\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370898
    m_Localized: "\u041C\u044B?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370899
    m_Localized: "\u0412\u0435\u0440\u043D\u043E, \u0441\u044B\u043D\u043E\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370900
    m_Localized: "\u041C\u0435\u043D\u044F \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0434\u043D\u043E
      \u0432\u043E\u043B\u043D\u0443\u0435\u0442: \u043E\u043D\u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043D\u0430\u0441 \u0442\u0430\u043A\u0438\u043C\u0438 \u0432\u0438\u0434\u0435\u043B\u0438?
      \u0418\u043B\u0438 \u044D\u0442\u043E \u0434\u043B\u044F \u0442\u043E\u0433\u043E,
      \u0447\u0442\u043E\u0431\u044B \u0438\u0445 \u0441\u043E\u043B\u0434\u0430\u0442\u044B
      \u0431\u0438\u043B\u0438\u0441\u044C \u043A\u0430\u043A \u0441\u043B\u0435\u0434\u0443\u0435\u0442?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370901
    m_Localized: "\u0420\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430 \u0432\u0441\u0435\u0433\u0434\u0430
      \u0432\u0438\u0434\u0435\u043B\u0430 \u0432 \u043D\u0430\u0441 \u0447\u0443\u0434\u043E\u0432\u0438\u0449.
      \u041D\u043E \u043E\u043D\u0438 \u0436\u0435 \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
      \u0436\u0433\u043B\u0438 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
      \u0437\u0435\u043C\u043B\u0438, \u0447\u0442\u043E\u0431\u044B \u043D\u0430\u0441
      \u0432\u044B\u043A\u0443\u0440\u0438\u0442\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370902
    m_Localized: "\u041E\u043F\u0440\u0430\u0432\u0434\u044B\u0432\u0430\u043B\u0438\u0441\u044C!
      \u0413\u043E\u0432\u043E\u0440\u0438\u043B\u0438, \u0447\u0442\u043E \u043D\u0435
      \u0443\u0441\u043F\u0435\u043B\u0438 \u044D\u0432\u0430\u043A\u0443\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u043C\u0438\u0440\u043D\u043E\u0435 \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u0435.
      \u0412\u0430\u0436\u043D\u043E \u043E\u0434\u043D\u043E: \u043E\u043D\u0438
      \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u043B\u0438 \u0432\u0441\u0451,
      \u0447\u0442\u043E \u0443\u0441\u043F\u0435\u043B\u0438, \u043B\u0438\u0448\u044C
      \u0431\u044B \u043D\u0430\u043C \u043D\u0435 \u0434\u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370903
    m_Localized: "\u041D\u043E, \u0442\u0430\u043A \u0438\u043B\u0438 \u0438\u043D\u0430\u0447\u0435,
      \u043C\u044B \u043F\u043E\u0431\u0435\u0434\u0438\u043B\u0438. \u0418 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438
      \u044D\u0442\u0438 \u0441\u0434\u0435\u043B\u0430\u043B\u0438 \u043D\u0430\u0448\u0435\u0439
      \u043A\u043E\u043B\u043E\u043D\u0438\u0435\u0439. \u041F\u043E\u0442\u043E\u043C\u0443
      \u0447\u0442\u043E \u043D\u0430\u0448\u0430 \u0441\u0442\u0440\u0430\u043D\u0430
      \u2013 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0430\u044F \u0438\u043C\u043F\u0435\u0440\u0438\u044F
      \u0441\u0432\u043E\u0435\u0439 \u044D\u043F\u043E\u0445\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370904
    m_Localized: "\u0412\u043E\u0442 \u0447\u0451\u0440\u0442! \u041E\u043D\u0438
      \u0438\u0434\u0443\u0442! \u0413\u043E\u0442\u043E\u0432\u044C\u0441\u044F
      \u043F\u043E\u0441\u044B\u043B\u0430\u0442\u044C \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B!"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370905
    m_Localized: "\u041A\u0430\u0436\u0435\u0442\u0441\u044F, \u043E\u0442\u0431\u0438\u043B\u0438\u0441\u044C.
      \u0421\u0435\u0440\u0436\u0430\u043D\u0442, \u0442\u044B \u043A\u0430\u043A?
      \u0416\u0438\u0432\u043E\u0439?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370906
    m_Localized: "\u0416\u0438\u0432\u043E\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370907
    m_Localized: "\u041D\u0443 \u0438 \u0441\u043B\u0430\u0432\u043D\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370908
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370909
    m_Localized: "\u041B\u0430\u0434\u043D\u043E. \u0422\u044B \u043E\u0442\u043B\u0438\u0447\u043D\u043E
      \u0441\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F. \u041C\u043E\u043B\u043E\u0434\u0435\u0446."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370910
    m_Localized: "\u041D\u0435\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370911
    m_Localized: "\u0425\u0430-\u0445\u0430. \u0412\u0438\u0436\u0443, \u0442\u044B
      \u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C \u043F\u043E\u0448\u0443\u0442\u0438\u0442\u044C.
      \u041E\u0434\u043E\u0431\u0440\u044F\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370912
    m_Localized: "\u041A\u0430\u043A \u0434\u0443\u043C\u0430\u0435\u0448\u044C,
      \u043F\u0440\u043E\u0442\u0438\u0432 \u043A\u043E\u0433\u043E \u043C\u044B
      \u0441\u0440\u0430\u0436\u0430\u0435\u043C\u0441\u044F?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370913
    m_Localized: "\u041A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u0435
      \u043C\u043E\u043B\u0447\u0438\u0442, \u0438 \u0432\u0441\u0435, \u0441 \u043A\u0435\u043C
      \u0431\u044B \u044F \u043D\u0435 \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u043B\u0441\u044F,
      \u0442\u043E\u0436\u0435 \u043D\u0438\u0447\u0435\u0440\u0442\u0430 \u043D\u0435
      \u0437\u043D\u0430\u044E\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370914
    m_Localized: "\u041E\u043A\u0430\u0436\u0435\u0442\u0441\u044F \u0435\u0449\u0451,
      \u0447\u0442\u043E \u043D\u0435 \u0432\u0440\u0430\u0433 \u044D\u0442\u043E
      \u0432\u043E\u0432\u0441\u0435. \u041C\u043E\u0436\u0435\u0442, \u043C\u044B
      \u0441 \u0441\u0430\u043C\u0438\u043C\u0438 \u0441\u043E\u0431\u043E\u0439
      \u0432\u043E\u044E\u0435\u043C?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370915
    m_Localized: "\u0421\u043B\u0443\u0448\u0430\u0439, \u0443 \u0442\u0435\u0431\u044F
      \u0442\u043E\u0436\u0435 \u0431\u043E\u0439\u043D\u0438\u0446\u0430 \u0437\u0430\u0432\u0430\u0440\u0435\u043D\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370916
    m_Localized: "\u0422\u0430\u043A \u0442\u043E\u0447\u043D\u043E. \u041D\u0438
      \u0435\u0434\u0438\u043D\u043E\u0439 \u0449\u0435\u043B\u0438, \u0434\u044B\u0448\u0430\u0442\u044C
      \u043D\u0435\u0447\u0435\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370917
    m_Localized: "\u0422\u044B \u0445\u043E\u0442\u044C \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0439
      \u0434\u0432\u0435\u0440\u044C \u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u0443\u044E
      \u0438\u043D\u043E\u0433\u0434\u0430. \u0413\u0440\u043E\u043C\u043A\u043E
      \u0441\u043A\u0430\u0437\u0430\u043D\u043E, \u043A\u043E\u043D\u0435\u0447\u043D\u043E,
      \u0434\u0432\u0435\u0440\u044C. \u0422\u0443\u0434\u0430 \u0438 \u0440\u0443\u043A\u0430
      \u043D\u0435 \u043F\u043E\u043C\u0435\u0441\u0442\u0438\u0442\u0441\u044F \u041D\u043E
      \u0445\u043E\u0442\u044C \u0432\u043E\u0437\u0434\u0443\u0445 \u0441\u0432\u0435\u0436\u0438\u0439
      \u0437\u0430\u043F\u0443\u0441\u0442\u0438\u0448\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370918
    m_Localized: "\u0410\u0433\u0430. \u0414\u0430\u0436\u0435 \u0441\u0432\u0435\u0442
      \u043D\u0435 \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370919
    m_Localized: "\u0422\u044B \u0434\u0435\u0440\u0436\u0438\u0441\u044C. \u041F\u0435\u0440\u0432\u043E\u0435
      \u0432\u0440\u0435\u043C\u044F \u0437\u0434\u0435\u0441\u044C \u0432\u0441\u0451
      \u0434\u0430\u0432\u0438\u0442, \u043F\u043E\u0442\u043E\u043C \u043F\u0440\u0438\u0432\u044B\u043A\u0430\u0435\u0448\u044C.
      \u0425\u043E\u0442\u044C \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0439 \u0434\u0432\u0435\u0440\u044C
      \u043D\u0430 \u0441\u043A\u043B\u0430\u0434. \u0422\u0430\u043A \u0431\u0443\u0434\u0435\u0442
      \u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F, \u0447\u0442\u043E \u043C\u0435\u0441\u0442\u0430
      \u043F\u043E\u0431\u043E\u043B\u044C\u0448\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370920
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370921
    m_Localized: "\u0417\u0430\u0433\u0440\u0443\u0437\u0438\u043B \u0442\u044B \u043C\u0435\u043D\u044F,
      \u0441\u0435\u0440\u0436\u0430\u043D\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370922
    m_Localized: "\u041F\u043E\u0439\u0434\u0443 \u043F\u0440\u0438\u043B\u044F\u0433\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370923
    m_Localized: "\u0418 \u0442\u0435\u0431\u0435 \u0442\u043E\u0436\u0435 \u0441\u0442\u043E\u0438\u0442.
      \u0421 \u0441\u0430\u043C\u043E\u0433\u043E \u043F\u0440\u0438\u0431\u044B\u0442\u0438\u044F
      \u0441\u044E\u0434\u0430 \u043D\u0438 \u043D\u0430 \u043C\u0438\u043D\u0443\u0442\u0443
      \u043D\u0435 \u043F\u0440\u0438\u0441\u0435\u043B"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370924
    m_Localized: "\u041F\u043E\u0441\u043F\u0438 \u043F\u043E\u043A\u0430 \u0438\u043B\u0438
      \u0435\u0449\u0451 \u0447\u0435\u043C \u0437\u0430\u0439\u043C\u0438\u0441\u044C.
      \u0421\u0438\u043B\u044B \u043D\u0430\u043C \u043F\u043E\u043A\u0430 \u043F\u0440\u0438\u0433\u043E\u0434\u044F\u0442\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370925
    m_Localized: "\u041A\u043E\u043D\u0435\u0446 \u0441\u0432\u044F\u0437\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370926
    m_Localized: "\u041D\u0443 \u0447\u0442\u043E, \u0441\u0435\u0440\u0436\u0430\u043D\u0442,
      \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u043F\u043E\u0441\u043F\u0430\u0442\u044C?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370927
    m_Localized: "\u042F \u0434\u0440\u0435\u043C\u0430\u043B \u043A\u043E\u0435-\u043A\u0430\u043A.
      \u0421\u044E\u0434\u0430 \u0431\u044B \u043F\u043E\u0434\u0443\u0448\u043A\u0443
      \u0441 \u043E\u0434\u0435\u044F\u043B\u043E\u043C\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370928
    m_Localized: "\u0418 \u043A\u043D\u0438\u0436\u043A\u0443 \u0431\u044B \u0445\u043E\u0440\u043E\u0448\u0443\u044E.
      \u042F \u0432\u043E\u0442 \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044F
      \u0434\u043B\u044F \u0441\u0435\u0431\u044F \u043E\u0442\u043A\u0440\u044B\u043B\u2026
      \u043A\u0430\u043A \u0435\u0433\u043E\u2026 \u0423\u044D\u043B\u043B\u0441!"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370929
    m_Localized: "\u041E\u043D, \u043A\u043E\u043D\u0435\u0447\u043D\u043E, \u043C\u0430\u0441\u0442\u0435\u0440
      \u0432\u044B\u0434\u0443\u043C\u044B..."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370930
    m_Localized: "\u041F\u0440\u0438\u0451\u043C, \u043A\u0430\u043A \u0441\u043B\u044B\u0448\u043D\u043E?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370931
    m_Localized: "\u041D\u0430 \u0441\u0432\u044F\u0437\u0438 \u043A\u043E\u043C\u0430\u043D\u0434\u0438\u0440
      \u042D\u0439\u043A\u0435\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370932
    m_Localized: "\u041F\u0440\u044F\u043C\u043E \u0441\u0435\u0439\u0447\u0430\u0441
      \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
      \u0432 \u043F\u043E\u0441\u0435\u043B\u0435\u043D\u0438\u0438 \u0414\u043E\u0442\u0442\u0438\u043D\u0433\u0435\u043C.
      \u041D\u0430\u0448 \u0440\u0430\u0434\u0430\u0440 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
      \u0435\u0433\u043E \u0437\u0430\u0441\u0435\u0447\u044C. \u041D\u043E \u043C\u044B
      \u0442\u043E\u0447\u043D\u043E \u0437\u043D\u0430\u0435\u043C, \u0447\u0442\u043E
      \u043E\u043D \u0442\u0430\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370933
    m_Localized: "\u041D\u0443\u0436\u043D\u043E \u0441\u0442\u0440\u0435\u043B\u044F\u0442\u044C
      \u043F\u043E \u0433\u043E\u0440\u043E\u0434\u0443 \u0432\u0441\u043B\u0435\u043F\u0443\u044E.
      \u0418\u043D\u0430\u0447\u0435 \u0432\u0440\u0430\u0433 \u0443\u0441\u043F\u0435\u0435\u0442
      \u0441\u0431\u0435\u0436\u0430\u0442\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370934
    m_Localized: "\u041F\u043E\u0432\u0442\u043E\u0440\u044F\u044E \u2013 \u0441\u0442\u0440\u0435\u043B\u044F\u0439\u0442\u0435
      \u043F\u043E \u0433\u043E\u0440\u043E\u0434\u0443 \u0414\u043E\u0442\u0442\u0438\u043D\u0433\u0435\u043C.
      \u041F\u0440\u0438\u0441\u0442\u0443\u043F\u0430\u0439\u0442\u0435 \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 43573370935
    m_Localized: "\u0421\u0435\u0440\u0436\u0430\u043D\u0442, \u0442\u044B \u0447\u0442\u043E
      \u0441\u0435\u0431\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0448\u044C?"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370936
    m_Localized: "\u041F\u043E\u0434 \u0442\u0440\u0438\u0431\u0443\u043D\u0430\u043B
      \u0437\u0430\u0445\u043E\u0442\u0435\u043B? \u042F \u0442\u0435\u0431\u0435
      \u044D\u0442\u043E \u043A\u0430\u043A \u043F\u0438\u0442\u044C \u0434\u0430\u0442\u044C
      \u0443\u0441\u0442\u0440\u043E\u044E! \u0411\u0443\u0434\u0435\u0448\u044C
      \u0443 \u043C\u0435\u043D\u044F \u043D\u0430 \u043A\u0430\u0442\u043E\u0440\u0433\u0435
      \u043B\u0435\u0441 \u0432\u0430\u043B\u0438\u0442\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370937
    m_Localized: "\u041F\u043E\u043C\u044F\u043D\u0438 \u043C\u043E\u0451 \u0441\u043B\u043E\u0432\u043E:
      \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0430\u043A \u0442\u044B \u043E\u0442\u0441\u044E\u0434\u0430
      \u043D\u0435 \u0443\u0439\u0434\u0451\u0448\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370938
    m_Localized: "\u0414\u043E\u0443\u044D\u043B, \u043E\u0442\u043A\u0440\u044B\u0442\u044C
      \u043E\u0433\u043E\u043D\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 43573370939
    m_Localized: "\u0421\u043A\u0430\u0436\u0438 \u0441\u043F\u0430\u0441\u0438\u0431\u043E
      \u042D\u0434\u0432\u0430\u0440\u0434\u0443. \u041D\u0435 \u0431\u0443\u0434\u044C
      \u0435\u0433\u043E \u2013 \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0436\u0435
      \u0431\u044B \u0432\u0441\u0442\u0430\u043B \u043A \u0441\u0442\u0435\u043D\u043A\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565184
    m_Localized: "\u041D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0441\u044F
      \u043A \u0441\u0432\u043E\u0438\u043C \u043E\u0431\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044F\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565185
    m_Localized: "\u0412\u0442\u043E\u0440\u043E\u0433\u043E \u0448\u0430\u043D\u0441\u0430
      \u0443 \u0442\u0435\u0431\u044F \u043D\u0435 \u0431\u0443\u0434\u0435\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565186
    m_Localized: "\u0421\u0435\u0440\u0436\u0430\u043D\u0442, \u0414\u043E\u0443\u044D\u043B,
      \u043F\u043E\u0437\u0434\u0440\u0430\u0432\u043B\u044F\u044E \u0441 \u0443\u0441\u043F\u0435\u0448\u043D\u043E\u0439
      \u0430\u0442\u0430\u043A\u043E\u0439. \u0420\u043E\u0434\u0438\u043D\u0430
      \u0432\u0430\u0441 \u043D\u0435 \u0437\u0430\u0431\u0443\u0434\u0435\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565187
    m_Localized: "\u042D\u0442\u043E\u0442 \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440
      - \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435. \u0412\u043F\u0440\u0435\u0434\u044C
      \u0442\u0430\u043A\u043E\u0433\u043E \u043D\u0435 \u043F\u043E\u0432\u0442\u043E\u0440\u0438\u0442\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565188
    m_Localized: "\u041D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u044E: \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
      \u0442\u0435\u043B\u0435\u0444\u043E\u043D \u0432\u043E \u0432\u0440\u0435\u043C\u044F
      \u0430\u0442\u0430\u043A\u0438 \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438
      \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565189
    m_Localized: "\u0414\u043E \u0441\u0432\u044F\u0437\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565190
    m_Localized: "\u042D\u0439, \u0441\u0435\u0440\u0436\u0430\u043D\u0442. \u0422\u044B
      \u043E\u0442\u043B\u0438\u0447\u043D\u043E \u0441\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565191
    m_Localized: "\u041D\u0435 \u0433\u0440\u044B\u0437\u0438 \u0441\u0435\u0431\u044F.
      \u041F\u0440\u0438\u043A\u0430\u0437 \u0435\u0441\u0442\u044C \u043F\u0440\u0438\u043A\u0430\u0437."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565192
    m_Localized: "\u0421\u0430\u043B\u0430\u0433\u0430, \u0442\u044B \u0443\u043C\u043E\u043C
      \u0442\u0440\u043E\u043D\u0443\u043B\u0441\u044F?"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565193
    m_Localized: "\u041F\u0440\u0438\u043A\u0430\u0437 \u0435\u0441\u0442\u044C \u043F\u0440\u0438\u043A\u0430\u0437."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565194
    m_Localized: "\u042D\u0442\u043E \u0431\u0435\u0441\u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u043E.
      \u0412 \u0433\u043E\u0440\u043E\u0434\u0435 \u043C\u043E\u0433\u043B\u0438
      \u043E\u0441\u0442\u0430\u0442\u044C\u0441\u044F \u043B\u044E\u0434\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565195
    m_Localized: "\u0411\u0443\u0434\u0435\u043C \u0441\u0447\u0438\u0442\u0430\u0442\u044C,
      \u0447\u0442\u043E \u044F \u044D\u0442\u043E\u0433\u043E \u043D\u0435 \u0441\u043B\u044B\u0448\u0430\u043B.
      \u0422\u044B \u0432\u043E\u043E\u0431\u0449\u0435 \u0447\u0435\u043C \u0434\u0443\u043C\u0430\u043B,
      \u043A\u043E\u0433\u0434\u0430 \u0432 \u0430\u0440\u043C\u0438\u044E \u043F\u043E\u0448\u0451\u043B?
      \u041C\u044B \u0437\u0434\u0435\u0441\u044C \u0443\u0431\u0438\u0432\u0430\u0435\u043C,
      \u0430 \u043D\u0435 \u0431\u0443\u043C\u0430\u0436\u043A\u0438 \u043F\u0435\u0440\u0435\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565196
    m_Localized: "\u0415\u0449\u0451 \u0440\u0430\u0437 \u0447\u0442\u043E-\u0442\u043E
      \u043F\u043E\u0434\u043E\u0431\u043D\u043E\u0435 \u043B\u044F\u043F\u043D\u0435\u0448\u044C
      \u2013 \u0441\u043E\u043E\u0431\u0449\u0443 \u043A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u044E
      \u0438 \u0436\u0430\u043B\u0435\u0442\u044C \u0442\u0435\u0431\u044F \u043D\u0435
      \u0431\u0443\u0434\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565197
    m_Localized: "\u0412\u044B \u043F\u0440\u0430\u0432\u044B. \u042F \u0434\u043E\u043B\u0436\u0435\u043D
      \u0431\u044B\u043B \u044D\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565198
    m_Localized: "\u0412\u043E\u0442 \u044D\u0442\u043E \u044F \u0438 \u0445\u043E\u0442\u0435\u043B
      \u0443\u0441\u043B\u044B\u0448\u0430\u0442\u044C. \u041F\u0440\u0435\u043A\u0440\u0430\u0442\u0438
      \u0441\u043E\u043F\u043B\u0438 \u043D\u0430 \u043A\u0443\u043B\u0430\u043A
      \u043D\u0430\u043C\u0430\u0442\u044B\u0432\u0430\u0442\u044C \u0438 \u0437\u0430\u0439\u043C\u0438\u0441\u044C
      \u0434\u0435\u043B\u043E\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565199
    m_Localized: "\u0418\u043D\u0430\u0447\u0435 \u0434\u043E\u043B\u0433\u043E \u0437\u0434\u0435\u0441\u044C
      \u043D\u0435 \u043F\u0440\u043E\u0442\u044F\u043D\u0435\u0448\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565200
    m_Localized: "\u042D\u0439, \u0441\u0435\u0440\u0436\u0430\u043D\u0442, \u0442\u044B
      \u0442\u0443\u0442?"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565201
    m_Localized: "\u042F \u0432\u0441\u0451 \u043C\u0435\u0441\u0442\u0430 \u0441\u0435\u0431\u0435
      \u043D\u0430\u0439\u0442\u0438 \u043D\u0435 \u043C\u043E\u0433\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565202
    m_Localized: "\u0427\u0442\u043E-\u0442\u043E \u043D\u0430 \u0441\u0435\u0440\u0434\u0446\u0435
      \u043D\u0435\u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565203
    m_Localized: "\u0414\u0443\u043C\u0430\u044E \u0432\u0441\u0451 \u043E \u043C\u0438\u0440\u043D\u043E\u0439
      \u0436\u0438\u0437\u043D\u0438: \u0447\u0442\u043E \u0441\u0435\u0439\u0447\u0430\u0441
      \u0441 \u0434\u043E\u043C\u043E\u043C? \u0427\u0435\u043C \u0441\u043E\u0441\u0435\u0434\u0438
      \u0437\u0430\u043D\u044F\u0442\u044B? \u0412 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438
      \u043B\u0438 \u0441\u0435\u043C\u044C\u044F?"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565204
    m_Localized: "\u0417\u043D\u0430\u044E, \u043D\u0435\u043B\u044C\u0437\u044F.
      \u041D\u043E \u0447\u0435\u043C \u0431\u043E\u043B\u044C\u0448\u0435 \u044D\u0442\u0438
      \u043C\u044B\u0441\u043B\u0438 \u0433\u043E\u043D\u044E, \u0442\u0435\u043C
      \u0441\u0438\u043B\u044C\u043D\u0435\u0435 \u043E\u043D\u0438 \u0432 \u043B\u0435\u0437\u0443\u0442
      \u0432 \u0433\u043E\u043B\u043E\u0432\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565205
    m_Localized: "\u0422\u044B \u0445\u043E\u0442\u044C \u043F\u0440\u043E \u0441\u0435\u0431\u044F
      \u0440\u0430\u0441\u0441\u043A\u0430\u0436\u0438, \u043E\u0442\u0432\u043B\u0435\u043A\u0438
      \u0441\u0442\u0430\u0440\u0438\u043A\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565206
    m_Localized: "\u042F \u0432 \u0430\u0440\u043C\u0438\u044E \u0441\u0440\u0430\u0437\u0443
      \u043F\u043E\u0441\u043B\u0435 \u0448\u043A\u043E\u043B\u044B \u043F\u043E\u0448\u0451\u043B."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565207
    m_Localized: "\u0412\u0440\u0435\u043C\u0435\u043D\u0438 \u0442\u044B \u0437\u0440\u044F
      \u043D\u0435 \u0442\u0435\u0440\u044F\u043B. \u042F \u0442\u043E\u0436\u0435
      \u0432 \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F \u0431\u0443\u043C\u0430\u0433\u0438
      \u0438\u0437 \u0448\u043A\u043E\u043B\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u043B,
      \u0438 \u0441\u0440\u0430\u0437\u0443 \u043D\u0430 \u0444\u0440\u043E\u043D\u0442.
      \u041C\u0438\u0440 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043B,
      \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043C\u0435\u0434\u0430\u043B\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565208
    m_Localized: "\u0412\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0434\u043E\u043C\u043E\u0439.
      \u041F\u0435\u0440\u0432\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u0441\u043B\u043E\u0436\u043D\u043E
      \u0431\u044B\u043B\u043E, \u043D\u043E \u043F\u0440\u0438\u0432\u044B\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565209
    m_Localized: "\u0421\u0442\u0430\u043B \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u043E\u043C,
      \u043D\u0430 \u0444\u0430\u0431\u0440\u0438\u043A\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B.
      \u0410 \u0442\u0435\u043F\u0435\u0440\u044C \u0441\u043D\u043E\u0432\u0430
      \u043A\u0438\u0442\u0435\u043B\u044C \u043D\u0430\u0434\u0435\u043B \u0438
      \u0431\u0443\u0434\u0442\u043E \u043D\u0435 \u0443\u0445\u043E\u0434\u0438\u043B
      \u043D\u0438\u043A\u0443\u0434\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565210
    m_Localized: "\u0422\u044B, \u043A\u0430\u043A \u0432\u0435\u0440\u043D\u0451\u0448\u044C\u0441\u044F,
      \u043D\u0435 \u0434\u0430\u0432\u0430\u0439 \u0441\u0435\u0431\u0435 \u0441
      \u0443\u043C\u0430 \u0441\u0445\u043E\u0434\u0438\u0442\u044C. \u0418 \u0435\u0441\u043B\u0438
      \u0434\u0430\u043C\u0430 \u0435\u0441\u0442\u044C \u2013 \u043D\u0435 \u043E\u0431\u0438\u0436\u0430\u0439.
      \u041D\u0435 \u0432\u0438\u043D\u043E\u0432\u0430\u0442\u0430 \u043E\u043D\u0430
      \u043D\u0438 \u0432 \u0447\u0435\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565211
    m_Localized: "\u042D\u0442\u043E \u0442\u044B \u0432 \u0430\u0434\u0443 \u0436\u0438\u043B,
      \u0430 \u0443 \u043D\u0435\u0451 \u043E\u043D \u0441\u0432\u043E\u0439. \u0416\u0434\u0451\u0442
      \u0442\u0435\u0431\u044F, \u0441\u0435\u0440\u0434\u0446\u0435\u043C \u043C\u0443\u0447\u0430\u0435\u0442\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565212
    m_Localized: "\u0423 \u043C\u0435\u043D\u044F \u043A\u043E\u0448\u043A\u0430
      \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C. \u041F\u0443\u0448\u0438\u043D\u043A\u0430
      \u0437\u043E\u0432\u0443\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565213
    m_Localized: "\u041D\u0443 \u043E\u043F\u044F\u0442\u044C \u0442\u044B \u043E
      \u0434\u043E\u043C\u0435! \u041D\u0443 \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B
      \u0436\u0435 \u043F\u0440\u043E \u0447\u0442\u043E-\u0442\u043E \u0434\u0440\u0443\u0433\u043E\u0435
      \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u0442\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565214
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565215
    m_Localized: "\u041C\u044B \u043B\u0435\u0442 \u043F\u044F\u0442\u044C \u043D\u0430\u0437\u0430\u0434
      \u0441\u043E\u0431\u0430\u043A\u0443 \u0437\u0430\u0432\u0435\u043B\u0438.
      \u0411\u0435\u043B\u0435\u043D\u044C\u043A\u0443\u044E, \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0443\u044E.
      \u041D\u0430 \u043C\u044B\u0448\u0435\u0439 \u043E\u0445\u043E\u0442\u0438\u0442\u0441\u044F
      \u043B\u0443\u0447\u0448\u0435 \u043B\u044E\u0431\u043E\u0439 \u043A\u043E\u0448\u043A\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565216
    m_Localized: "\u0410 \u0436\u0435\u043D\u0430 \u043C\u043E\u044F \u2013 \u0448\u0432\u0435\u044F,
      \u0442\u0430\u043A \u041C\u0438\u043C\u0438 \u2013 \u0435\u0451 \u0433\u043B\u0430\u0432\u043D\u0430\u044F
      \u043C\u043E\u0434\u0435\u043B\u044C. \u041E\u043D\u0430 \u0435\u0439 \u0442\u043E
      \u043A\u043E\u0441\u0442\u044E\u043C\u0447\u0438\u043A, \u0442\u043E \u0448\u0430\u043F\u043E\u0447\u043A\u0443.
      \u0420\u0430\u043D\u044C\u0448\u0435 \u0442\u0430\u043A \u0434\u0435\u0442\u0435\u0439
      \u043E\u0434\u0435\u0432\u0430\u043B\u0430, \u0442\u043E\u043B\u044C\u043A\u043E
      \u0432\u044B\u0440\u043E\u0441\u043B\u0438 \u043E\u043D\u0438 \u0432\u0441\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565217
    m_Localized: "\u042F \u0432\u0441\u0451 \u0433\u043E\u0432\u043E\u0440\u044E:
      \u043A\u0443\u0434\u0430 \u0442\u044B \u0441 \u043F\u0441\u0438\u043D\u043E\u0439
      \u0442\u0430\u043A \u0432\u043E\u0437\u0438\u0448\u044C\u0441\u044F. \u0410
      \u043E\u043D\u0430 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0438\u043D\u0430\u0447\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565218
    m_Localized: "\u041F\u0443\u0441\u0442\u044C \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442\u0441\u044F,
      \u043F\u043E\u043A\u0430 \u043C\u0435\u043D\u044F \u0441\u0430\u043C\u043E\u0433\u043E
      \u0432 \u0447\u0435\u043F\u0447\u0438\u043A \u043D\u0435 \u043E\u0434\u0435\u043B\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565219
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565220
    m_Localized: "\u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0443\u0433\u043B\u0438
      \u0432 \u043A\u0430\u043C\u0438\u043D\u0435 \u043F\u043E\u0447\u0442\u0438
      \u043E\u0441\u0442\u044B\u043B\u0438, \u0442\u0430\u043A \u041C\u0438\u043C\u0438
      \u0437\u0430\u0431\u0440\u0430\u043B\u0430\u0441\u044C \u0442\u0443\u0434\u0430
      \u0438 \u0432\u0441\u044E \u043D\u043E\u0447\u044C \u0441\u043F\u0430\u043B\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565221
    m_Localized: "\u042F \u0442\u043E\u0433\u0434\u0430 \u043E\u0442 \u0441\u0442\u0440\u0430\u0445\u0430
      \u0447\u0443\u0442\u044C \u043D\u0435 \u043F\u043E\u043C\u0435\u0440. \u0421\u043F\u0443\u0441\u043A\u0430\u044E\u0441\u044C
      \u0432\u043D\u0438\u0437 \u2013 \u0430 \u0442\u0430\u043C \u0432 \u0442\u0435\u043C\u043D\u043E\u0442\u0435
      \u043E\u0434\u043D\u0438 \u0433\u043B\u0430\u0437\u0430 \u0434\u0430 \u0437\u0443\u0431\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565222
    m_Localized: "\u0412\u043E\u0442 \u0441\u043C\u0435\u0445\u0443-\u0442\u043E
      \u0431\u044B\u043B\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565223
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565224
    m_Localized: "\u0421\u043A\u043E\u0440\u0435\u0435 \u0431\u044B \u0434\u043E\u043C\u043E\u0439
      \u0443\u0436\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565225
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565226
    m_Localized: "\u0422\u044B \u044D\u0442\u043E \u0441\u043B\u044B\u0448\u0430\u043B?"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565227
    m_Localized: "\u0427\u0442\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442?"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565228
    m_Localized: "\u042D\u0442\u043E \u0447\u0442\u043E \u0435\u0449\u0451 \u0437\u0430\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565229
    m_Localized: "\u0422\u043E\u0432\u0430\u0440\u0438\u0449 \u0441\u0435\u0440\u0436\u0430\u043D\u0442,
      \u043D\u0430 \u0441\u0432\u044F\u0437\u0438 \u043A\u043E\u043C\u0430\u043D\u0434\u0438\u0440
      \u042D\u0439\u043A\u0435\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565230
    m_Localized: "\u041C\u0438\u0441\u0441\u0438\u044F \u043F\u043E \u044D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u0438
      \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u044F
      \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0430 \u0443\u0441\u043F\u0435\u0448\u043D\u043E.
      \u0418\u043C\u043F\u0435\u0440\u0438\u044F \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0438\u0442
      \u0432\u0430\u0441 \u0437\u0430 \u0441\u043B\u0443\u0436\u0431\u0443. "
    m_Metadata:
      m_Items: []
  - m_Id: 43577565231
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565232
    m_Localized: "\u042D\u0442\u043E \u0435\u0449\u0451 \u0447\u0442\u043E \u0442\u0430\u043A\u043E\u0435?"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565233
    m_Localized: "\u041E\u043D\u043E \u043B\u0435\u0442\u0438\u0442 \u0432 \u043D\u0430\u0448\u0443
      \u0441\u0442\u043E\u0440\u043E\u043D\u0443! \u0414\u043E\u043B\u043E\u0436\u0438\u0442\u0435
      \u0442\u043E\u0432\u0430\u0440\u0438\u0449\u0443 \u043F\u043E\u043B\u043A\u043E\u0432\u043D\u0438\u043A\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565234
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565235
    m_Localized: "\u0412\u0441\u0435 \u0446\u0435\u043B\u044B?"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565236
    m_Localized: "\u0422\u043E\u0432\u0430\u0440\u0438\u0449\u0438, \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E
      \u043E\u0442\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u043F\u0430\u043D\u0438\u043A\u0443!
      \u042D\u0442\u043E \u043D\u0435\u0440\u0430\u0437\u043E\u0440\u0432\u0430\u0432\u0448\u0438\u0439\u0441\u044F
      \u0441\u043D\u0430\u0440\u044F\u0434."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565237
    m_Localized: "\u0422\u043E\u043B\u044C\u043A\u043E \u0444\u043E\u0440\u043C\u0430
      \u0443 \u043D\u0435\u0433\u043E \u043A\u0430\u043A\u0430\u044F-\u0442\u043E
      \u0441\u0442\u0440\u0430\u043D\u043D\u0430\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565238
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565239
    m_Localized: "\u0412\u0441\u0435\u043C\u0443 \u043B\u0438\u0447\u043D\u043E\u043C\u0443
      \u0441\u043E\u0441\u0442\u0430\u0432\u0443 \u043A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u044F:
      \u043D\u0435\u0437\u0430\u043C\u0435\u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043F\u0440\u043E\u0441\u043B\u0435\u0434\u0443\u0439\u0442\u0435 \u0432 \u0443\u0431\u0435\u0436\u0438\u0449\u0435
      \u043D\u0430 \u043C\u0438\u043D\u0443\u0441 \u0442\u0440\u0435\u0442\u0438\u0439
      \u044D\u0442\u0430\u0436."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565240
    m_Localized: "\u0414\u0430 \u0431\u0440\u043E\u0441\u044C \u0442\u044B \u044D\u0442\u0438
      \u0431\u0443\u043C\u0430\u0436\u043A\u0438! \u041C\u044B \u0441\u0435\u0439\u0447\u0430\u0441
      \u0437\u0434\u0435\u0441\u044C \u043D\u0430\u0445\u0440\u0435\u043D \u043F\u043E\u043B\u044F\u0436\u0435\u043C!"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565241
    m_Localized: "\u041F\u043E\u0432\u0442\u043E\u0440\u044F\u044E. \u0412\u0441\u0435\u043C\u0443
      \u043B\u0438\u0447\u043D\u043E\u043C\u0443 \u0441\u043E\u0441\u0442\u0430\u0432\u0443
      \u043A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u044F: \u043D\u0435\u0437\u0430\u043C\u0435\u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043F\u0440\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C \u0432
      \u0443\u0431\u0435\u0436\u0438\u0449\u0435 \u043D\u0430 \u043C\u0438\u043D\u0443\u0441
      \u0442\u0440\u0435\u0442\u0438\u0439 \u044D\u0442\u0430\u0436."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565242
    m_Localized: "\u0413\u043E\u0441\u043F\u043E\u0434\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565243
    m_Localized: "\u0410\u0410\u0410\u0410\u0410\u0410\u0410\u0410\u0410!"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565244
    m_Localized: "\u042D\u0439? \u0421\u0435\u0440\u0436\u0430\u043D\u0442?"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565245
    m_Localized: "\u0422\u044B \u0441\u043B\u0430\u0432\u043D\u044B\u0439 \u043C\u0430\u043B\u044B\u0439\u2026
      \u0425\u043E\u0440\u043E\u0448\u043E \u043C\u044B \u0441 \u0442\u043E\u0431\u043E\u0439
      \u043F\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565246
    m_Localized: "\u0422\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u043F\u0435\u0440\u044C
      \u0431\u043E\u043B\u044C\u043D\u043E \u0447\u0435\u0433\u043E-\u0442\u043E.
      \u0412\u0438\u0434\u0430\u0442\u044C, \u043F\u043E\u0447\u043A\u0438 \u043E\u043F\u044F\u0442\u044C
      \u0432\u043E\u0441\u043F\u0430\u043B\u0438\u043B\u0438\u0441\u044C\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565247
    m_Localized: "\u041D\u0430\u0434\u043E \u0431\u044B\u043B\u043E \u0448\u0430\u0440\u0444\u043E\u043C
      \u043F\u0440\u0438\u043A\u0440\u044B\u0432\u0430\u0442\u044C, \u043A\u0430\u043A
      \u0436\u0435\u043D\u0430 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0430.
      \u0410 \u044F, \u0434\u0443\u0440\u0430\u043A, \u043D\u0435 \u0441\u043B\u0443\u0448\u0430\u043B."
    m_Metadata:
      m_Items: []
  - m_Id: 43577565248
    m_Localized: "\u0422\u044B\u2026 \u042D\u0442\u043E\u2026 \u0412\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u0439
      \u043C\u0435\u043D\u044F \u043D\u0430 \u0434\u0435\u043D\u044C \u0432\u043E\u0438\u043D\u0441\u043A\u043E\u0439
      \u0441\u043B\u0430\u0432\u044B, \u0445\u043E\u0440\u043E\u0448\u043E?"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565249
    m_Localized: "\u0411\u044B\u0432\u0430\u0439\u2026 \u0421\u0435\u0440\u0436\u0430\u043D\u0442\u0438\u043A\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 43577565250
    m_Localized: "\u041D\u0430\u0432\u043E\u0434\u0447\u0438\u043A! \u041E\u0442\u043A\u0440\u044B\u0432\u0430\u0439
      \u0434\u0432\u0435\u0440\u044C. \u0417\u0430\u043F\u0443\u0441\u0442\u0438\u0448\u044C? "
    m_Metadata:
      m_Items: []
  - m_Id: 43581759488
    m_Localized: "\u041A\u0430\u043A \u0441\u043B\u044B\u0448\u043D\u043E? \u041D\u0430
      \u0441\u0432\u044F\u0437\u0438 \u0448\u0442\u0430\u0431."
    m_Metadata:
      m_Items: []
  - m_Id: 43581759489
    m_Localized: "\u041A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u044E
      \u043D\u0430\u043D\u0435\u0441\u0435\u043D\u044B \u043D\u0435\u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
      \u043F\u043E\u0432\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u044F. \u041C\u044B
      \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0438\u0440\u0443\u0435\u043C \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 43581759490
    m_Localized: "\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0442\u0435\u0441\u044C
      \u043A \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044E \u043E\u0431\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u0435\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 43581759491
    m_Localized: "\u0412\u044B \u043C\u0435\u043D\u044F \u0441\u043B\u044B\u0448\u0438\u0442\u0435?
      \u042D\u0442\u043E \u0448\u0442\u0430\u0431."
    m_Metadata:
      m_Items: []
  - m_Id: 43581759492
    m_Localized: "\u0421\u0435\u0440\u0436\u0430\u043D\u0442, \u0432\u0430\u043C
      \u0441\u0442\u043E\u0438\u0442 \u0431\u044B\u0442\u044C \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u0435\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 43581759493
    m_Localized: "\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u043D\u0430\u043B\u0451\u0442
      \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u0443\u0449\u0435\u0440\u0431 \u0437\u0434\u0430\u043D\u0438\u044E \u043A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 43581759494
    m_Localized: "\u0414\u043E\u043B\u0433\u043E \u043C\u044B \u0442\u0430\u043A
      \u043D\u0435 \u043F\u0440\u043E\u0442\u044F\u043D\u0435\u043C. \u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430,
      \u0437\u0430\u0449\u0438\u0442\u0438\u0442\u0435 \u043D\u0430\u0441."
    m_Metadata:
      m_Items: []
  - m_Id: 43581759495
    m_Localized: "\u0421\u0435\u0440\u0436\u0430\u043D\u0442! \u042D\u0442\u043E
      \u0448\u0442\u0430\u0431."
    m_Metadata:
      m_Items: []
  - m_Id: 43581759496
    m_Localized: "\u0418\u0437-\u0437\u0430 \u0432\u0430\u0448\u0435\u0439 \u0431\u0435\u0437\u0430\u043B\u0430\u0431\u0435\u0440\u043D\u043E\u0441\u0442\u0438
      \u043F\u043E\u0434 \u0443\u0433\u0440\u043E\u0437\u043E\u0439 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
      \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0448\u0442\u0430\u0431\u0430
      \u043A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u044F, \u043D\u043E
      \u0438 \u0446\u0435\u043B\u043E\u0439 \u0418\u043C\u043F\u0435\u0440\u0438\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 43581759497
    m_Localized: "\u0421\u0438\u0442\u0443\u0430\u0446\u0438\u044F \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F.
      \u0415\u0449\u0451 \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u2013 \u0438
      \u0437\u0434\u0430\u043D\u0438\u0435 \u043E\u0431\u0432\u0430\u043B\u0438\u0442\u0441\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 43581759498
    m_Localized: "\u041D\u0435 \u0434\u0430\u0439\u0442\u0435 \u044D\u0442\u0438\u043C
      \u0442\u0432\u0430\u0440\u044F\u043C \u0442\u0443\u0442 \u0432\u0441\u0435\u0445
      \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u0442\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 43581759499
    m_Localized: "\u0414\u043E\u0442\u0438\u043D\u0433\u0435\u0439\u043C"
    m_Metadata:
      m_Items: []
  - m_Id: 43581759500
    m_Localized: "\u041C\u0430\u0433\u0433\u0438\u043D\u0441\u0445\u043E\u043B"
    m_Metadata:
      m_Items: []
  - m_Id: 43581759501
    m_Localized: "\u0413\u0440\u0438\u043D\u0444\u043E\u043B"
    m_Metadata:
      m_Items: []
  - m_Id: 43581759502
    m_Localized: "\u041C\u043E\u0440\u0435 \u042D\u0448\u0435\u043D"
    m_Metadata:
