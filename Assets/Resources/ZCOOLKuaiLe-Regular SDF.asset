    characterSetSelectionMode: 7
    characterSequence: "\u5F00\u59CB\u6E38\u620F\r\n\u8BBE\u7F6E\r\n\u9000\u51FA\u6E38\u620F\r\n\u97F3\u6548\u97F3\u91CF\r\n\u97F3\u4E50\u97F3\u91CF\r\n\u6309\u4E0B\r\n\u4E92\u52A8\r\n\u957F\u6309\r\n\u56DE\u590D\r\n\u786E\u8BA4\r\n\u53D6\u6D88\r\n\r\n\u60A8\u597D\uFF0C\u4E2D\u58EB\u540C\u5FD7\u3002\u6211\u53EB\u7231\u5FB7\u534E\xB7\u9053\u5C14\uFF0C\u662F\u4E00\u540D\u70AE\u5175\u3002\u4F60\u662F\u6211\u7684\u7784\u51C6\u624B\u3002\r\n\u5E1D\u56FD\u519B\u961F\u6B63\u5728\u64A4\u79BB\u5E73\u6C11\u3002\u6211\u4EEC\u7684\u804C\u8D23\u662F\u4E3A\u4ED6\u4EEC\u63D0\u4F9B\u63A9\u62A4\u3002\r\n\u9996\u5148\uFF0C\u542F\u52A8\u684C\u5B50\u4E0A\u7684\u5730\u56FE\u3002\u90A3\u91CC\u6709\u5F00\u5173\u3002\r\n\u542F\u52A8\u4E86\u5417\uFF1F\u505A\u5F97\u597D\u3002\r\n\u7784\u51C6\u624B\uFF0C\u4F60\u5FC5\u987B\u628A\u654C\u519B\u7684\u5750\u6807\u4F20\u7ED9\u6211\u3002\u654C\u519B\u5728\u5730\u56FE\u4E0A\u7528\u7EA2\u70B9\u6807\u51FA\u3002\r\n\u4E00\u770B\u89C1\u8FD9\u6837\u7684\u7EA2\u70B9\uFF0C\u7ACB\u523B\u6253\u7535\u62A5\u3002\r\n\u5343\u4E07\u4E0D\u8981\u7528\u7535\u8BDD\u3002\u6307\u6325\u90E8\u63D0\u9632\u7A83\u542C\u3002\u53EA\u80FD\u6253\u7535\u62A5\uFF01\r\n\u5982\u679C\u542C\u5230\u8B66\u62A5\uFF0C\u5C31\u8BF4\u660E\u654C\u519B\u5F00\u59CB\u653B\u51FB\u4E86\u3002\u901A\u8BAF\u4F1A\u88AB\u7ACB\u523B\u5207\u65AD\uFF0C\u522B\u6307\u671B\u5B83\u3002\r\n\u4F60\u7B97\u8D70\u8FD0\uFF0C\u6218\u573A\u4E0A\u8FD8\u6709\u4E2A\u6B8B\u654C\u3002\u4ED6\u8FD8\u6D3B\u7740\uFF0C\u4F46\u4E0D\u80FD\u52A8\u3002\r\n\u597D\u6B79\u5148\u628A\u8FD9\u91CC\u600E\u4E48\u56DE\u4E8B\u5F04\u660E\u767D\uFF0C\u8D81\u7740\u8FD8\u6CA1\u706B\u70E7\u7709\u6BDB\u3002\r\n\u6211\u518D\u8BF4\u4E00\u904D\uFF1A\u770B\u5230\u90A3\u4E2A\u7EA2\u70B9\uFF0C\u522B\u7B49\uFF0C\u7ACB\u523B\u628A\u5B83\u7684\u5750\u6807\u53D1\u7ED9\u6211\u3002\r\n\u771F\u5012\u9709\u3002\u6211\u4EEC\u82B1\u4E86\u4E94\u5E74\uFF0C\u624D\u8BA9\u8FD9\u7247\u571F\u5730\u5F52\u4E8E\u6211\u4EEC\u3002\r\n\u53EF\u654C\u4EBA\u5374\u5728\u77ED\u77ED\u51E0\u5C0F\u65F6\u5185\u5C31\u628A\u6211\u4EEC\u7684\u9632\u5FA1\u5DE5\u4E8B\u6467\u6BC1\u6B86\u5C3D\u2026\u2026\r\n\u505A\u5F97\u597D\uFF0C\u4E2D\u58EB\uFF01\u4F60\u770B\uFF0C\u4E0D\u662F\u90A3\u4E48\u96BE\u3002\u6211\u53EF\u4E0D\u662F\u5403\u7D20\u7684\uFF0C\u4F60\u5728\u6211\u8EAB\u8FB9\u5F88\u5B89\u5168\u3002\r\n\u6211\u5C31\u60F3\u95EE\uFF0C\u73B0\u5728\u7684\u5E74\u8F7B\u4EBA\u5230\u5E95\u77E5\u4E0D\u77E5\u9053\u5E1D\u56FD\u90A3\u4E9B\u4F1F\u5927\u7684\u5F81\u670D\uFF1F\r\n\u73B0\u5728\u5B66\u6821\u91CC\u90FD\u600E\u4E48\u8BF4\u6211\u4EEC\uFF1F\r\n\u51E0\u4E4E\u6CA1\u6709\uFF1A\u4E5F\u5C31\u80CC\u80CC\u51E0\u4E2A\u65E5\u671F\u548C\u7ED3\u8BBA\u3002\r\n\u771F\u7684\u5417\uFF1F\u8FD9\u662F\u5728\u57F9\u517B\u4E00\u4EE3\u8FF7\u5931\u7684\u4EBA\u3002\u522B\u5FD8\u4E86\uFF0C\u6211\u4EEC\u53EF\u662F\u4E3A\u4E86\u5E1D\u56FD\u7684\u5229\u76CA\u8D70\u8FC7\u4E00\u906D\u5730\u72F1\uFF01\r\n\u6BCF\u5E74\u90FD\u6709\u4E00\u8282\u4E13\u9898\u8BFE\u3002\u6211\u7684\u5386\u53F2\u8001\u5E08\u4E5F\u5BF9\u90A3\u4E2A\u65F6\u4EE3\u5341\u5206\u75F4\u8FF7\u3002\r\n\u4F60\u8FD9\u4E48\u8BF4\uFF0C\u6211\u592A\u5F00\u5FC3\u4E86\u3002\u56FD\u5BB6\u8FD8\u8BB0\u5F97\u6211\u4EEC\u7684\u529F\u52CB\uFF0C\u8FD9\u603B\u5F52\u662F\u597D\u4E8B\u3002\r\n\u6218\u6597\u5C31\u53D1\u751F\u5728\u8FD9\u91CC\u3002\u8FD9\u91CC\u5F88\u957F\u4E00\u6BB5\u65F6\u95F4\u90FD\u5C5E\u4E8E\u6211\u4EEC\u3002\u6B63\u662F\u591A\u4E8F\u4E86\u6211\u4EEC\u8FD9\u6837\u7684\u4EBA\uFF0C\u5E1D\u56FD\u624D\u53D8\u5F97\u66F4\u5F3A\u5927\u3002\r\n\u2026\r\n\u4F60\u90A3\u8FB9\u4E5F\u6302\u7740\u8FD9\u4E9B\u6D77\u62A5\u5417\uFF1F\u4F60\u89C9\u5F97\u6D77\u62A5\u4E0A\u753B\u7684\u662F\u4EC0\u4E48\u602A\u7269\uFF1F\r\n\u4E0D\u77E5\u9053\u3002\r\n\u5C31\u662F\u6211\u4EEC\u554A\uFF01\u4F60\u6562\u4FE1\u5417\uFF1F\uFF01\u8FD9\u4E9B\u8138\u4E5F\u592A\u96BE\u770B\u4E86\u5427\uFF01\u6211\u53EF\u80FD\u4E0D\u7B97\u6700\u5E05\u7684\u7537\u4EBA\uFF0C\u4F46\u5728\u8FD9\u513F\u6211\u7B80\u76F4\u50CF\u4E2A\u4E11\u516B\u602A\u3002\r\n\u662F\u6211\u4EEC\u5417\uFF1F\r\n\u5BF9\u4E86\uFF0C\u5C0F\u4F19\u3002\r\n\u6211\u53EA\u5728\u610F\u4E00\u4EF6\u4E8B\uFF1A\u4ED6\u4EEC\u771F\u7684\u628A\u6211\u4EEC\u770B\u6210\u8FD9\u6837\u5417\uFF1F\u8FD8\u662F\u8BF4\uFF0C\u8FD9\u662F\u4E3A\u4E86\u8BA9\u4ED6\u4EEC\u7684\u58EB\u5175\u6253\u5F97\u66F4\u51F6\uFF1F\r\n\u5171\u548C\u56FD\u4E00\u76F4\u628A\u6211\u4EEC\u89C6\u4E3A\u602A\u7269\u3002\u53EF\u4ED6\u4EEC\u751A\u81F3\u70B9\u706B\u711A\u70E7\u81EA\u5DF1\u7684\u571F\u5730\uFF0C\u5C31\u60F3\u628A\u6211\u4EEC\u903C\u51FA\u6765\uFF01\r\n\u8FD8\u627E\u501F\u53E3\uFF01\u4ED6\u4EEC\u8FD8\u8FA9\u79F0\u6CA1\u6765\u5F97\u53CA\u64A4\u79BB\u5E73\u6C11\u3002\u91CD\u70B9\u5728\u4E8E\uFF1A\u4ED6\u4EEC\u628A\u80FD\u6BC1\u7684\u90FD\u6BC1\u4E86\uFF0C\u5C31\u4E3A\u4E86\u4E0D\u8BA9\u5B83\u843D\u5230\u6211\u4EEC\u624B\u91CC\u3002\r\n\u4F46\u65E0\u8BBA\u5982\u4F55\uFF0C\u6211\u4EEC\u8D62\u4E86\u3002\u6211\u4EEC\u628A\u8FD9\u7247\u571F\u5730\u53D8\u6210\u4E86\u6211\u4EEC\u7684\u6B96\u6C11\u5730\u3002\u56E0\u4E3A\u6211\u4EEC\u7684\u56FD\u5BB6\u662F\u90A3\u4E2A\u65F6\u4EE3\u6700\u4F1F\u5927\u7684\u5E1D\u56FD\uFF01\r\n\u771F\u89C1\u9B3C\uFF01\u4ED6\u4EEC\u6765\u4E86\uFF01\u51C6\u5907\u53D1\u7ED9\u6211\u5750\u6807\uFF01\r\n\u770B\u6765\u628A\u654C\u4EBA\u51FB\u9000\u4E86\u3002\u4E2D\u58EB\uFF0C\u4F60\u600E\u4E48\u6837\uFF1F\u8FD8\u6D3B\u7740\u5427\uFF1F\r\n\u6D3B\u7740\u3002\r\n\u90A3\u5C31\u597D\u3002\r\n\u2026\r\n\u597D\u5427\u3002\u4F60\u505A\u5F97\u5F88\u4E0D\u9519\u3002\u505A\u5F97\u597D\u3002\r\n\u4E0D\u3002\r\n\u54C8\u54C8\u3002\u4F60\u633A\u7231\u5F00\u73A9\u7B11\u7684\u561B\u3002\u6211\u5F88\u8D5E\u540C\u3002\r\n\u4F60\u89C9\u5F97\u6211\u4EEC\u5728\u548C\u8C01\u4F5C\u6218\uFF1F\r\n\u6307\u6325\u90E8\u4FDD\u6301\u6C89\u9ED8\uFF0C\u800C\u6211\u8054\u7CFB\u8FC7\u7684\u6240\u6709\u4EBA\u4E5F\u90FD\u4E00\u65E0\u6240\u77E5\u3002\r\n\u6216\u8BB8\u8FD9\u6839\u672C\u4E0D\u662F\u654C\u4EBA\u3002\u6216\u8BB8\u6211\u4EEC\u662F\u5728\u548C\u81EA\u5DF1\u4F5C\u6218\uFF1F\r\n\u563F\uFF0C\u4F60\u90A3\u8FB9\u7684\u5C04\u5B54\u4E5F\u88AB\u710A\u6B7B\u4E86\u5417\uFF1F\r\n\u662F\u3002\u8FDE\u6761\u7F1D\u90FD\u6CA1\u6709\uFF0C\u95F7\u5F97\u5598\u4E0D\u8FC7\u6C14\u3002\r\n\u4F60\u8D77\u7801\u4E5F\u5F97\u5076\u5C14\u628A\u901A\u98CE\u53E3\u7684\u98CE\u95E8\u6253\u5F00\u4E00\u4E0B\u3002\u53EB\u5B83\u201C\u95E8\u201D\u4E5F\u592A\u5938\u5F20\u4E86\u3002\u8FDE\u624B\u90FD\u4F38\u4E0D\u8FDB\u53BB\u4F46\u597D\u6B79\u80FD\u900F\u70B9\u65B0\u9C9C\u7A7A\u6C14\u8FDB\u6765\u3002\r\n\u55EF\u3002\u8FDE\u5149\u90FD\u900F\u4E0D\u8FC7\u6765\u3002\r\n\u575A\u6301\u4F4F\u3002\u4E00\u5F00\u59CB\u4F1A\u89C9\u5F97\u5F88\u538B\u6291\uFF0C\u6162\u6162\u5C31\u4E60\u60EF\u4E86\u3002\u81F3\u5C11\u628A\u5E93\u623F\u7684\u95E8\u5F00\u5F00\u3002\u8FD9\u6837\u4F1A\u663E\u5F97\u7A7A\u95F4\u5927\u4E00\u70B9\u3002\r\n\u2026\r\n\u4E2D\u58EB\uFF0C\u4F60\u53EF\u7ED9\u6211\u538B\u4E86\u4E0D\u5C11\u62C5\u5B50\u554A\u3002\r\n\u6211\u53BB\u8EBA\u4E00\u4F1A\u513F\u3002\r\n\u4F60\u4E5F\u8BE5\u4F11\u606F\u4E00\u4E0B\u3002\u81EA\u6253\u5230\u8FD9\u513F\u8D77\uFF0C\u8FDE\u4E00\u5206\u949F\u90FD\u6CA1\u5750\u4E0B\u6765\u6B47\u8FC7\u3002\r\n\u53BB\u7761\u4F1A\u513F\uFF0C\u6216\u8005\u627E\u70B9\u522B\u7684\u4E8B\u505A\u3002\u6211\u4EEC\u8FD8\u5F97\u7559\u7740\u529B\u6C14\u3002\r\n\u5B8C\u6BD5\u3002\r\n\u600E\u4E48\u6837\uFF0C\u4E2D\u58EB\uFF0C\u7761\u4E86\u4E00\u4F1A\u513F\u5417\uFF1F\r\n\u6211\u5C31\u968F\u4FBF\u6253\u4E86\u4E2A\u76F9\u513F\u3002\u8981\u662F\u8FD9\u513F\u6709\u6795\u5934\u548C\u6BEF\u5B50\u5C31\u597D\u4E86\u2026\u2026\r\n\u518D\u6709\u4E00\u672C\u597D\u4E66\u5C31\u66F4\u597D\u4E86\u3002\u6211\u6700\u8FD1\u53D1\u73B0\u4E86\u4E2A\u4F5C\u5BB6\u2026\u53EB\u4EC0\u4E48\u2026\u5A01\u5C14\u65AF\uFF01\r\n\u4ED6\u7F16\u6545\u4E8B\u53EF\u771F\u662F\u4E00\u7EDD\u2026\u2026\r\n\u547C\u53EB\uFF0C\u542C\u5F97\u5230\u5417\uFF1F\r\n\u8FD9\u91CC\u662F\u827E\u80AF\u6307\u6325\u5B98\u3002\r\n\u654C\u519B\u6B64\u523B\u5C31\u5728\u591A\u5EF7\u6C49\u59C6\u5B9A\u5C45\u70B9\u5185\u3002\u6211\u4EEC\u7684\u96F7\u8FBE\u65E0\u6CD5\u63A2\u6D4B\u5230\u4ED6\u4EEC\u3002\u4F46\u6211\u4EEC\u786E\u4FE1\u4ED6\u5C31\u5728\u90A3\u91CC\u3002\r\n\u9700\u8981\u5BF9\u8BE5\u57CE\u8FDB\u884C\u76F2\u5C04\u3002\u5426\u5219\u654C\u4EBA\u4F1A\u9003\u8131\u3002\r\n\u7ACB\u5373\u6267\u884C\u3002\r\n\u4E2D\u58EB\uFF0C\u4F60\u4EE5\u4E3A\u81EA\u5DF1\u5728\u5E72\u4EC0\u4E48\u5462\uFF1F\r\n\u60F3\u4E0A\u519B\u4E8B\u6CD5\u5EAD\u662F\u5427\uFF1F\u6211\u4E00\u5B9A\u8BA9\u4F60\u4E0A\u519B\u6CD5\uFF0C\u7B49\u7740\u5427\uFF01\u6211\u770B\u4F60\u662F\u60F3\u53BB\u52B3\u6539\u8425\u780D\u6811\u4E86\uFF01\r\n\u4F60\u7ED9\u6211\u8BB0\u4F4F\uFF1A\u4F60\u4E0D\u53EF\u80FD\u5C31\u8FD9\u4E48\u8F7B\u6613\u8131\u8EAB\uFF01\r\n\u9053\u5C14\uFF0C\u5F00\u706B\uFF01\r\n\u4F60\u5F97\u611F\u8C22\u7231\u5FB7\u534E\u3002\u8981\u4E0D\u662F\u4ED6\uFF0C\u4F60\u4ECA\u5929\u5C31\u88AB\u67AA\u6BD9\u4E86\u3002\r\n\u7ACB\u5373\u56DE\u5230\u4F60\u7684\u5C97\u4F4D\u4E0A\u53BB\u3002\r\n\u4F60\u4E0D\u4F1A\u518D\u6709\u7B2C\u4E8C\u6B21\u673A\u4F1A\u4E86\u3002\r\n\u4E2D\u58EB\u3001\u9053\u5C14\uFF0C\u795D\u8D3A\u4F60\u4EEC\u6210\u529F\u5B8C\u6210\u653B\u51FB\u3002\u7956\u56FD\u4E0D\u4F1A\u5FD8\u8BB0\u4F60\u4EEC\u3002\r\n\u8FD9\u6B21\u8C08\u8BDD\u662F\u4E2A\u4F8B\u5916\u3002\u4E0B\u4E0D\u4E3A\u4F8B\u3002\r\n\u6211\u91CD\u7533\uFF1A\u653B\u51FB\u671F\u95F4\u4E25\u7981\u4F7F\u7528\u7535\u8BDD\uFF01\r\n\u5B8C\u6BD5\u3002\r\n\u5582\uFF0C\u4E2D\u58EB\u3002\u4F60\u505A\u5F97\u5F88\u4E0D\u9519\u3002\r\n\u522B\u592A\u81EA\u8D23\u4E86\u3002\u547D\u4EE4\u5C31\u662F\u547D\u4EE4\u3002\r\n\u83DC\u9E1F\uFF0C\u4F60\u75AF\u4E86\u5417\uFF1F\r\n\u547D\u4EE4\u5C31\u662F\u547D\u4EE4\u3002\r\n\u8FD9\u592A\u4E0D\u4EBA\u9053\u4E86\u3002\u57CE\u91CC\u53EF\u80FD\u8FD8\u6709\u4EBA\u3002\r\n\u6211\u5C31\u5F53\u6CA1\u542C\u89C1\u3002\u4F60\u5F53\u5175\u7684\u65F6\u5019\u8111\u5B50\u91CC\u5728\u60F3\u4EC0\u4E48\uFF1F\u6211\u4EEC\u662F\u6765\u6253\u4ED7\u6740\u654C\u7684\uFF0C\u4E0D\u662F\u6765\u6446\u5F04\u6587\u4EF6\u7684\u3002\r\n\u4F60\u518D\u6562\u4E71\u8BF4\u8BDD\uFF0C\u6211\u5C31\u5411\u4E0A\u7EA7\u62A5\u544A\uFF0C\u7EDD\u4E0D\u7559\u60C5\u3002\r\n\u60A8\u8BF4\u5F97\u5BF9\u3002\u6211\u5FC5\u987B\u8FD9\u4E48\u505A\u3002\r\n\u8FD9\u6B63\u662F\u6211\u60F3\u542C\u5230\u7684\u3002\u522B\u5728\u8FD9\u513F\u78E8\u78E8\u5527\u5527\uFF0C\u53BB\u5E72\u6D3B\u3002\r\n\u4E0D\u7136\u4F60\u5728\u8FD9\u513F\u6491\u4E0D\u4E86\u591A\u4E45\u3002\r\n\u5582\uFF0C\u4E2D\u58EB\uFF0C\u4F60\u5728\u5417\uFF1F\r\n\u6211\u5750\u7ACB\u4E0D\u5B89\u3002\r\n\u5FC3\u91CC\u6709\u70B9\u4E0D\u5B89\u3002\r\n\u6211\u603B\u60E6\u8BB0\u5BB6\u91CC\u7684\u65E5\u5B50\uFF0C\u4E0D\u77E5\u9053\u73B0\u5728\u600E\u4E48\u6837\u4E86\u3002\u90BB\u5C45\u4EEC\u90FD\u5728\u5FD9\u4EC0\u4E48\u5462\uFF1F\u5BB6\u4EBA\u90FD\u5B89\u5168\u5417\uFF1F\r\n\u6211\u77E5\u9053\u4E0D\u8BE5\u8FD9\u4E48\u60F3\u3002\u53EF\u6211\u8D8A\u662F\u8D76\u8D70\u8FD9\u4E9B\u5FF5\u5934\uFF0C\u5B83\u4EEC\u5C31\u8D8A\u662F\u5F80\u8111\u5B50\u91CC\u94BB\u3002\r\n\u4F60\u5012\u662F\u8BB2\u8BB2\u4F60\u81EA\u5DF1\uFF0C\u8BA9\u6211\u8FD9\u8001\u5BB6\u4F19\u5206\u5206\u5FC3\u3002\r\n\u6211\u4E2D\u5B66\u4E00\u6BD5\u4E1A\u5C31\u53C2\u519B\u4E86\u3002\r\n\u4F60\u4E00\u70B9\u65F6\u95F4\u90FD\u6CA1\u6D6A\u8D39\u3002\u6211\u4E5F\u662F\uFF0C\u5F53\u5E74\u62FF\u4E86\u6BD5\u4E1A\u8BC1\u5C31\u76F4\u63A5\u4E0A\u4E86\u524D\u7EBF\u3002\u89C1\u4E86\u89C1\u4E16\u9762\uFF0C\u5F97\u4E86\u679A\u5956\u7AE0\u3002\r\n\u7136\u540E\u5C31\u56DE\u4E86\u5BB6\u3002\u4E00\u5F00\u59CB\u4E0D\u4E60\u60EF\uFF0C\u4F46\u540E\u6765\u4E5F\u9002\u5E94\u4E86\u3002\r\n\u5F53\u4E86\u6280\u5DE5\uFF0C\u5728\u5DE5\u5382\u5DE5\u4F5C\u3002\u800C\u73B0\u5728\u53C8\u7A7F\u4E0A\u4E86\u8FD9\u8EAB\u519B\u88C5\uFF0C\u611F\u89C9\u5C31\u50CF\u4ECE\u6765\u6CA1\u79BB\u5F00\u8FC7\u4E00\u6837\u3002\r\n\u7B49\u4F60\u56DE\u53BB\u540E\uFF0C\u522B\u628A\u81EA\u5DF1\u903C\u75AF\u3002\u8981\u662F\u5BB6\u91CC\u6709\u4F4D\u59D1\u5A18\uFF0C\u522B\u4E8F\u5F85\u4E86\u5979\u3002\u5979\u6CA1\u6709\u4EFB\u4F55\u9519\u3002\r\n\u4F60\u5728\u5730\u72F1\u91CC\u8FC7\u65E5\u5B50\uFF0C\u5979\u4E5F\u6709\u5979\u81EA\u5DF1\u7684\u5730\u72F1\u3002\u5979\u5728\u7B49\u4F60\uFF0C\u5FC3\u91CC\u4E3A\u4F60\u7275\u80A0\u6302\u809A\u3002\r\n\u6211\u5BB6\u91CC\u8FD8\u7559\u7740\u53EA\u732B\u3002\u5B83\u53EB\u201C\u6BDB\u6BDB\u201D\u3002\r\n\u4F60\u600E\u4E48\u53C8\u8BF4\u8D77\u5BB6\u91CC\u7684\u4E8B\u4E86\uFF01\u4E0D\u662F\u8981\u804A\u70B9\u522B\u7684\u5417\uFF01\r\n\u2026\r\n\u6211\u4EEC\u5927\u6982\u4E94\u5E74\u524D\u517B\u4E86\u53EA\u72D7\u3002\u767D\u767D\u7684\uFF0C\u5C0F\u5C0F\u7684\u3002\u5B83\u6293\u8001\u9F20\u6BD4\u732B\u8FD8\u5389\u5BB3\uFF01\r\n\u6211\u8001\u5A46\u662F\u88C1\u7F1D\uFF0C\u4E8E\u662F\u7C73\u7C73\u5C31\u6210\u4E86\u5979\u7684\u4E13\u5C5E\u6A21\u7279\u3002\u4E0D\u662F\u7ED9\u5B83\u505A\u5957\u5C0F\u8863\u670D\uFF0C\u5C31\u662F\u7EC7\u9876\u5C0F\u5E3D\u5B50\u3002\u4EE5\u524D\u5979\u4E5F\u8FD9\u6837\u6253\u626E\u5B69\u5B50\u4EEC\uFF0C\u4F46\u73B0\u5728\u4ED6\u4EEC\u90FD\u957F\u5927\u4E86\u3002\r\n\u6211\u603B\u8DDF\u5979\u8BF4\uFF1A\u4F60\u81F3\u4E8E\u4E3A\u4E00\u6761\u72D7\u6298\u817E\u6210\u8FD9\u6837\u5417\uFF1F\u53EF\u5979\u5C31\u662F\u5FCD\u4E0D\u4F4F\u3002\r\n\u968F\u5979\u53BB\u5427\uFF0C\u53EA\u8981\u522B\u54EA\u5929\u7ED9\u6211\u4E5F\u6234\u4E0A\u5A74\u513F\u5E3D\u5C31\u884C\u3002\r\n\u2026\r\n\u6709\u4E00\u6B21\u58C1\u7089\u91CC\u7684\u70AD\u706B\u90FD\u5FEB\u7184\u4E86\uFF0C\u7C73\u7C73\u5C31\u94BB\u8FDB\u53BB\u7761\u4E86\u4E00\u6574\u665A\u3002\r\n\u6211\u5F53\u65F6\u5DEE\u70B9\u6CA1\u5413\u6B7B\u3002\u6211\u4E0B\u697C\u4E00\u770B\uFF0C\u9ED1\u6697\u4E2D\u5C31\u770B\u89C1\u4E00\u53CC\u773C\u775B\u548C\u7259\u9F7F\u3002\r\n\u53EF\u628A\u6211\u4EEC\u7B11\u574F\u4E86\u3002\r\n\u2026\r\n\u771F\u5E0C\u671B\u80FD\u65E9\u70B9\u56DE\u5BB6\u3002\r\n\u2026\r\n\u4F60\u542C\u5230\u4E86\u5417\uFF1F\r\n\u600E\u4E48\u56DE\u4E8B\uFF1F\r\n\u8FD9\u53C8\u662F\u2026\r\n\u4E2D\u58EB\u540C\u5FD7\uFF0C\u8FD9\u91CC\u662F\u827E\u80AF\u6307\u6325\u5B98\u3002\r\n\u5E73\u6C11\u758F\u6563\u4EFB\u52A1\u5DF2\u6210\u529F\u5B8C\u6210\u3002\u5E1D\u56FD\u611F\u8C22\u4F60\u